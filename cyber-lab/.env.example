# Lab secrets template
# Copy this file to .env and replace every placeholder with strong, unique values.
# .env is gitignored and must never be committed.

# Local Windows Vagrant box credentials (default for these boxes is 'vagrant')
LAB_VAGRANT_USER=vagrant
LAB_VAGRANT_PW=<set local vagrant password>

# DSRM safe-mode password for the domain controller
LAB_DSRM_PW=<set DSRM password>

# Domain accounts created by scripts/provision-dc-step2.ps1
LAB_ALICE_PW=<set strong password for alice>
LAB_BOB_PW=<set strong password for bob>
LAB_CAROL_PW=<set strong password for carol>
LAB_SVC_SQL_PW=<set strong password for svc_sql>
LAB_SVC_WEB_PW=<set strong password for svc_web>

# Wazuh dashboard admin password
LAB_WAZUH_DASHBOARD_PW=<set Wazuh dashboard password>
