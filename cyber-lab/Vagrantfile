# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # Phase 3 network:
  #   Lab-Internal: 10.10.0.0/24  (Kali, SIEM, router inside)
  #   TargetNet:    10.20.0.0/24  (Juice Shop target, router target-side)
  #   ADNet:        10.30.0.0/24  (Windows DC + client, router AD-side)

  config.vm.define "router" do |router|
    router.vm.box = "ubuntu/jammy64"
    router.vm.hostname = "lab-router"
    router.vm.network "private_network", ip: "10.10.0.2"
    router.vm.network "private_network", ip: "10.20.0.2"
    router.vm.network "private_network", ip: "10.30.0.2"
    router.vm.provider "virtualbox" do |vb|
      vb.name = "lab-router"
      vb.memory = 1024
      vb.cpus = 1
      vb.gui = false
    end
    router.vm.provision "shell", inline: <<-SHELL
      set -e
      export DEBIAN_FRONTEND=noninteractive
      apt-get update -y
      apt-get install -y iptables-persistent net-tools curl

      # Enable IP forwarding
      sysctl -w net.ipv4.ip_forward=1
      echo 'net.ipv4.ip_forward=1' > /etc/sysctl.d/99-lab-router.conf

      # Determine WAN interface (default route)
      WAN=$(ip route | awk '/^default/ {print $5; exit}')

      # Make rules idempotent on reprovision
      iptables -F
      iptables -t nat -F
      iptables -P FORWARD ACCEPT

      # Allow forwarding between all lab segments
      for src in 10.10.0.0/24 10.20.0.0/24 10.30.0.0/24; do
        for dst in 10.10.0.0/24 10.20.0.0/24 10.30.0.0/24; do
          [ "$src" = "$dst" ] && continue
          iptables -A FORWARD -s "$src" -d "$dst" -j ACCEPT
        done
      done
      iptables -A FORWARD -m state --state ESTABLISHED,RELATED -j ACCEPT

      # NAT for outbound traffic on WAN
      iptables -t nat -A POSTROUTING -o "$WAN" -j MASQUERADE

      netfilter-persistent save
      echo "Router ready: 10.10.0.2 / 10.20.0.2 / 10.30.0.2"
    SHELL
  end

  config.vm.define "siem" do |siem|
    siem.vm.box = "ubuntu/jammy64"
    siem.vm.hostname = "lab-siem"
    siem.vm.network "private_network", ip: "10.10.0.30"
    siem.vm.provider "virtualbox" do |vb|
      vb.name = "lab-siem"
      vb.memory = 6144
      vb.cpus = 2
      vb.gui = false
    end
    siem.vm.provision "shell", inline: <<-SHELL
      set -e
      export DEBIAN_FRONTEND=noninteractive
      apt-get update -y
      apt-get install -y curl git docker.io docker-compose
      systemctl enable --now docker

      # Routes to target and AD subnets via router
      ip route add 10.20.0.0/24 via 10.10.0.2 || true
      ip route add 10.30.0.0/24 via 10.10.0.2 || true

      # Wazuh needs this for the indexer
      sysctl -w vm.max_map_count=262144
      echo 'vm.max_map_count=262144' > /etc/sysctl.d/99-wazuh.conf

      # Wazuh single-node deployment
      WAZUH_BRANCH="v4.10.1"
      if [ ! -d /opt/wazuh-docker ]; then
        git clone --depth 1 --branch "$WAZUH_BRANCH" https://github.com/wazuh/wazuh-docker.git /opt/wazuh-docker
      fi
      cd /opt/wazuh-docker/single-node
      # Generate certs if not present
      if [ ! -f config/wazuh-indexer/wazuh.indexer.pem ]; then
        docker-compose -f generate-indexer-certs.yml run --rm generator
      fi
      docker-compose up -d

      # Install custom AD detection rules into the Wazuh manager
      # (use ruleset/rules with a high prefix so they load after the built-in Security rules)
      CUSTOM_RULE="/vagrant/wazuh-rules/custom_ad_rules.xml"
      if [ -f "$CUSTOM_RULE" ]; then
        echo "Installing custom AD detection rules..."
        docker cp "$CUSTOM_RULE" single-node_wazuh.manager_1:/var/ossec/ruleset/rules/0599-custom_ad_rules.xml
        docker exec single-node_wazuh.manager_1 /var/ossec/bin/wazuh-control restart
      fi

      echo "Wazuh dashboard: https://10.10.0.30 (admin / SecretPassword)"
    SHELL
  end

  config.vm.define "kali" do |kali|
    kali.vm.box = "kalilinux/rolling"
    kali.vm.hostname = "kali-lab"
    kali.vm.network "private_network", ip: "10.10.0.10"
    kali.vm.provider "virtualbox" do |vb|
      vb.name = "lab-kali"
      vb.memory = 2048
      vb.cpus = 2
      vb.gui = false
    end
    kali.vm.provision "shell", inline: <<-SHELL
      set -e
      export DEBIAN_FRONTEND=noninteractive
      apt-get update -y
      apt-get install -y bloodhound.py netexec ligolo-ng gnupg apt-transport-https
      # Routes to target and AD subnets via router
      ip route add 10.20.0.0/24 via 10.10.0.2 || true
      ip route add 10.30.0.0/24 via 10.10.0.2 || true
      # Wazuh agent
      curl -s https://packages.wazuh.com/key/GPG-KEY-WAZUH | \
        gpg --no-default-keyring --keyring gnupg-ring:/usr/share/keyrings/wazuh.gpg --import
      chmod 644 /usr/share/keyrings/wazuh.gpg
      echo "deb [signed-by=/usr/share/keyrings/wazuh.gpg] https://packages.wazuh.com/4.x/apt/ stable main" | \
        tee /etc/apt/sources.list.d/wazuh.list
      apt-get update -y
      WAZUH_MANAGER="10.10.0.30" apt-get install -y --allow-downgrades \
        -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold" \
        wazuh-agent=4.10.1-1
      systemctl daemon-reload
      systemctl enable --now wazuh-agent
      echo "Kali ready at 10.10.0.10"
    SHELL
  end

  config.vm.define "target" do |target|
    target.vm.box = "ubuntu/jammy64"
    target.vm.hostname = "juice-shop"
    target.vm.network "private_network", ip: "10.20.0.20"
    target.vm.provider "virtualbox" do |vb|
      vb.name = "lab-juice-shop"
      vb.memory = 1536
      vb.cpus = 1
      vb.gui = false
    end
    target.vm.provision "shell", inline: <<-SHELL
      set -e
      export DEBIAN_FRONTEND=noninteractive
      apt-get update -y
      apt-get install -y docker.io gnupg apt-transport-https
      systemctl enable --now docker
      # Routes to lab and AD subnets via router
      ip route add 10.10.0.0/24 via 10.20.0.2 || true
      ip route add 10.30.0.0/24 via 10.20.0.2 || true
      # Wazuh agent
      curl -s https://packages.wazuh.com/key/GPG-KEY-WAZUH | \
        gpg --no-default-keyring --keyring gnupg-ring:/usr/share/keyrings/wazuh.gpg --import
      chmod 644 /usr/share/keyrings/wazuh.gpg
      echo "deb [signed-by=/usr/share/keyrings/wazuh.gpg] https://packages.wazuh.com/4.x/apt/ stable main" | \
        tee /etc/apt/sources.list.d/wazuh.list
      apt-get update -y
      WAZUH_MANAGER="10.10.0.30" apt-get install -y --allow-downgrades \
        -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold" \
        wazuh-agent=4.10.1-1
      systemctl daemon-reload
      systemctl enable --now wazuh-agent
      docker pull bkimminich/juice-shop:latest
      docker stop juice-shop >/dev/null 2>&1 || true
      docker rm juice-shop >/dev/null 2>&1 || true
      docker run -d --name juice-shop -p 3000:3000 --restart=unless-stopped bkimminich/juice-shop:latest
      echo "Juice Shop ready at http://10.20.0.20:3000"
    SHELL
  end

  # Windows Active Directory Domain Controller
  config.vm.define "dc" do |dc|
    dc.vm.box = "gusztavvargadr/windows-server-2022-standard"
    dc.vm.box_version = "2601.0.0"
    dc.vm.hostname = "dc01"
    dc.vm.guest = :windows
    dc.vm.communicator = "winrm"
    dc.vm.network "private_network", ip: "10.30.0.10"

    dc.winrm.username = "vagrant"
    dc.winrm.password = "vagrant"
    dc.winrm.transport = :plaintext
    dc.winrm.basic_auth_only = true
    dc.vm.boot_timeout = 1800
    dc.winrm.timeout = 1800
    dc.winrm.retry_limit = 30
    dc.winrm.retry_delay = 10

    dc.vm.provider "virtualbox" do |vb|
      vb.name = "lab-dc01"
      vb.memory = 3072
      vb.cpus = 2
      vb.gui = false
    end

    dc.vm.provision "shell", path: "scripts/provision-dc-step1.ps1", powershell_args: "-ExecutionPolicy Bypass -NoProfile"
    dc.vm.provision :reload
    dc.vm.provision "shell", path: "scripts/provision-dc-step2.ps1", powershell_args: "-ExecutionPolicy Bypass -NoProfile"
  end

  # Windows 10 domain client
  config.vm.define "win10" do |win10|
    win10.vm.box = "StefanScherer/windows_10"
    win10.vm.box_version = "2021.12.09"
    win10.vm.hostname = "win10-1"
    win10.vm.guest = :windows
    win10.vm.communicator = "winrm"
    win10.vm.network "private_network", ip: "10.30.0.11"

    win10.winrm.username = "vagrant"
    win10.winrm.password = "vagrant"
    win10.winrm.transport = :plaintext
    win10.winrm.basic_auth_only = true
    win10.vm.boot_timeout = 1800
    win10.winrm.timeout = 1800
    win10.winrm.retry_limit = 30
    win10.winrm.retry_delay = 10

    win10.vm.provider "virtualbox" do |vb|
      vb.name = "lab-win10-1"
      vb.memory = 2048
      vb.cpus = 2
      vb.gui = false
    end

    win10.vm.provision "shell", path: "scripts/provision-win10-step1.ps1", powershell_args: "-ExecutionPolicy Bypass -NoProfile"
    win10.vm.provision :reload
    win10.vm.provision "shell", path: "scripts/provision-win10-step2.ps1", powershell_args: "-ExecutionPolicy Bypass -NoProfile"
  end
end
